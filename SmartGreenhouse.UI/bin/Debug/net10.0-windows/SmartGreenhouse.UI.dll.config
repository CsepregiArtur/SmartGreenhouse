<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <add name="GreenhouseDB" 
         connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=SmartGreenhouseDB;Integrated Security=True" 
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="SimulationIntervalSeconds" value="5"/>
    <add key="EnableSoundAlerts" value="true"/>
    <add key="MaxAlertsInList" value="50"/>
  </appSettings>
</configuration>